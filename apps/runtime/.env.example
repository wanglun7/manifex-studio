UPSTREAM_OPENAI_MODEL=openai/gpt-5.4-mini
UPSTREAM_OPENAI_BASE_URL=http://127.0.0.1:8080/v1
UPSTREAM_OPENAI_API_KEY=replace-me

DASHSCOPE_API_KEY=replace-me
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
EMBEDDING_MODEL=text-embedding-v4
RERANKER_MODEL=qwen3-rerank
EMBED_DIM=1024

TAVILY_API_KEY=replace-me
TAVILY_MCP_URL=https://mcp.tavily.com/mcp/

MASTRA_PORT=4111
AGENT_MAX_STEPS=50

MANIFEX_DEFAULT_ORG_ID=default
MANIFEX_DEFAULT_ORG_NAME=Manifex
MANIFEX_BOOTSTRAP_OWNER_EMAIL=owner@manifex.local
MANIFEX_BOOTSTRAP_OWNER_PASSWORD=owner-token
MANIFEX_DEV_MEMBER_PASSWORD=member-token
MANIFEX_MEMBER_AGENT_IDS=feishu-agent,dingtalk-agent,wecom-agent,wps-agent
MANIFEX_OWNER_AGENT_IDS=*
MANIFEX_SESSION_TTL_MS=604800000

# Optional: when configured, Manifex uses OpenFGA OSS directly.
# Do not configure Mastra server.rbac/server.fga for production authz.
# OPENFGA_API_URL=http://127.0.0.1:8080
# OPENFGA_STORE_ID=
# OPENFGA_AUTHORIZATION_MODEL_ID=
# OPENFGA_API_TOKEN=

WORKSPACE_SANDBOX_PROVIDER=docker
WORKSPACE_DOCKER_IMAGE=manifex-agent-runtime:latest
WORKSPACE_THREAD_ROOT=artifacts/docker-thread-workspaces
WORKSPACE_DOCKER_MEMORY_BYTES=2147483648
WORKSPACE_DOCKER_PIDS_LIMIT=512
WORKSPACE_DOCKER_TIMEOUT_MS=300000

WORKSPACE_SANDBOX_CLEANUP_ENABLED=true
WORKSPACE_SANDBOX_IDLE_STOP_MS=3600000
WORKSPACE_SANDBOX_IDLE_REMOVE_MS=86400000
WORKSPACE_SANDBOX_SWEEP_INTERVAL_MS=300000

OBSERVATION_MESSAGE_TOKENS=100000
REFLECTION_OBSERVATION_TOKENS=120000
OBSERVATION_BUFFER_TOKENS=false
OBSERVATION_BUFFER_ON_IDLE=false

{
  "name": "@mastra/browser-firecrawl",
  "version": "0.1.3-alpha.0",
  "description": "Mastra browser automation using Firecrawl Browser Sandbox (hosted CDP + agent-browser tools)",
  "type": "module",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup --silent --config tsup.config.ts",
    "build:watch": "tsup --watch --silent --config tsup.config.ts",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "license": "Apache-2.0",
  "dependencies": {
    "firecrawl": "^4.18.4"
  },
  "devDependencies": {
    "@internal/lint": "workspace:*",
    "@internal/types-builder": "workspace:*",
    "@mastra/agent-browser": "workspace:*",
    "@mastra/core": "workspace:*",
    "@types/node": "22.19.21",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "agent-browser": "0.19.0",
    "eslint": "^10.4.1",
    "playwright-core": "^1.60.0",
    "tsup": "^8.5.1",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@mastra/agent-browser": ">=0.3.0 <1.0.0",
    "@mastra/core": ">=1.22.0-0 <2.0.0-0",
    "agent-browser": ">=0.19.0"
  },
  "homepage": "https://mastra.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mastra-ai/mastra.git",
    "directory": "browser/firecrawl"
  },
  "bugs": {
    "url": "https://github.com/mastra-ai/mastra/issues"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}

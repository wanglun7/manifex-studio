{
  "name": "@mastra/evals",
  "version": "1.3.1-alpha.0",
  "description": "",
  "type": "module",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "homepage": "https://mastra.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mastra-ai/mastra.git",
    "directory": "packages/evals"
  },
  "bugs": {
    "url": "https://github.com/mastra-ai/mastra/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./scorers/prebuilt": {
      "import": {
        "types": "./dist/scorers/prebuilt/index.d.ts",
        "default": "./dist/scorers/prebuilt/index.js"
      },
      "require": {
        "types": "./dist/scorers/prebuilt/index.d.ts",
        "default": "./dist/scorers/prebuilt/index.cjs"
      }
    },
    "./scorers/utils": {
      "import": {
        "types": "./dist/scorers/utils.d.ts",
        "default": "./dist/scorers/utils.js"
      },
      "require": {
        "types": "./dist/scorers/utils.d.ts",
        "default": "./dist/scorers/utils.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "build:lib": "pnpm check && tsup --silent --config tsup.config.ts",
    "prepack": "tsx ../../scripts/generate-package-docs.ts",
    "build:watch": "pnpm build:lib --watch",
    "test": "vitest",
    "lint": "eslint ."
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "compromise": "^14.15.0",
    "keyword-extractor": "^0.0.28",
    "sentiment": "^5.0.2",
    "string-similarity": "^4.0.4"
  },
  "peerDependencies": {
    "@mastra/core": ">=1.0.0-0 <2.0.0-0"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^1.3.24",
    "@internal/ai-sdk-v5": "workspace:*",
    "@internal/lint": "workspace:*",
    "@internal/llm-recorder": "workspace:*",
    "@internal/test-utils": "workspace:*",
    "@internal/types-builder": "workspace:*",
    "@mastra/core": "workspace:*",
    "@types/sentiment": "^5.0.4",
    "@types/string-similarity": "^4.0.2",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "tsup": "^8.5.1",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "engines": {
    "node": ">=22.13.0"
  }

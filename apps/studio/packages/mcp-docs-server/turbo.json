{
  "$schema": "https://v2-9-16.turborepo.dev/schema.json",
  "extends": ["//"],
  "tasks": {
    "prepare-docs": {
      "cache": false,
      "dependsOn": ["mastra-docs#build"],
      "outputs": [".docs/**"]
    },
    "build:cli": {
      "inputs": [
        "src/**",
        "tsup.config.ts",
        "tsconfig.json",
        "package.json",
        "!**/*.md",
        "!**/*.test.ts",
        "!**/*.spec.ts",
        "!**/__tests__/**"
      ],
      "outputs": ["dist/**", "!dist/docs/**"],
      "dependsOn": ["^build"]
    },
    "build": {
      "dependsOn": ["build:cli", "prepare-docs"],
      "inputs": ["package.json"]
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": []
    }
  }
}

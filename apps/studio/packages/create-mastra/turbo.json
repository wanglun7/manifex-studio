{
  "$schema": "https://v2-9-16.turborepo.dev/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build",
        "@mastra/core#build",
        "@mastra/libsql#build",
        "@mastra/observability#build",
        "@mastra/memory#build",
        "@mastra/loggers#build",
        "@mastra/evals#build",
        "@mastra/duckdb#build"
      ],
      "inputs": [
        "src/**",
        "tsup.config.ts",
        "tsconfig.json",
        "package.json",
        "!**/*.md",
        "!**/*.test.ts",
        "!**/*.spec.ts",
        "!**/__tests__/**"
      ],
      "outputs": ["dist/**", "!dist/docs/**"]
    }
  }
}

{
  "$schema": "https://v2-9-16.turborepo.dev/schema.json",
  "extends": ["//"],
  "tasks": {
    "build:lib": {
      "dependsOn": ["^build", "@mastra/server#generate:api-cli-route-metadata"],
      "outputs": ["dist/**", "!dist/docs/**"],
      "inputs": ["$TURBO_DEFAULT$", "./tsup.config.ts"]
    },
    "build": {
      "dependsOn": ["^build", "build:lib", "@internal/playground#build"],
      "inputs": ["package.json"],
      "outputs": ["dist/**", "!dist/docs/**"]
    }
  }
}

{
  "name": "@mastra/playground-ui",
  "type": "module",
  "version": "34.0.1-alpha.1",
  "description": "Mastra Playground components",
  "main": "dist/index.umd.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "theme.css",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.es.js"
      }
    },
    "./style.css": "./dist/index.css",
    "./theme.css": "./theme.css",
    "./tokens": {
      "import": {
        "types": "./dist/tokens.d.ts",
        "default": "./dist/tokens.es.js"
      },
      "require": {
        "types": "./dist/tokens.d.ts",
        "default": "./dist/tokens.cjs.js"
      }
    },
    "./utils": {
      "import": {
        "types": "./dist/utils.d.ts",
        "default": "./dist/utils.es.js"
      },
      "require": {
        "types": "./dist/utils.d.ts",
        "default": "./dist/utils.cjs.js"
      }
    },
    "./components/*": {
      "import": {
        "types": "./dist/components/*.d.ts",
        "default": "./dist/components/*.es.js"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest",
    "typecheck": "tsc",
    "lint": "eslint .",
    "build:publish": "pnpm build && yalc push",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build"
  },
  "keywords": [
    "mastra",
    "playground",
    "components"
  ],
  "author": "Mastra",
  "license": "Apache-2.0",
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/merge": "^6.12.2",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@hello-pangea/dnd": "^18.0.1",
    "@lezer/highlight": "^1.2.3",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@tanstack/react-virtual": "^3.13.22",
    "@uiw/codemirror-theme-dracula": "^4.25.10",
    "@uiw/react-codemirror": "^4.25.10",
    "cmdk": "^1.1.1",
    "date-fns": "catalog:",
    "prettier": "^3.8.3",
    "react-day-picker": "^8.10.1",
    "react-markdown": "^9.1.0",
    "react-resizable-panels": "^4.7.3",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^1.29.2",
    "sonner": "^2.0.7",
    "use-debounce": "^10.1.0",
    "zustand": "^5.0.12"
  },
  "peerDependencies": {
    "@mastra/client-js": "workspace:^",
    "@mastra/core": ">=1.7.1-0 <2.0.0-0",
    "@mastra/react": "workspace:*",
    "@tanstack/react-query": "^5.90.21",
    "lucide-react": "^0.474.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@internal/lint": "workspace:*",
    "@mastra/client-js": "workspace:^",
    "@mastra/core": "workspace:*",
    "@mastra/react": "workspace:*",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/react-vite": "^10.4.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/react-query": "^5.90.21",
    "@testing-library/react": "^16.3.2",
    "@types/json-schema": "^7.0.15",
    "@types/node": "22.19.21",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/ui": "catalog:",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.4.2",
    "jsdom": "^26.1.0",
    "msw": "^2.12.11",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rollup-plugin-node-externals": "^8.1.2",
    "storybook": "^10.4.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "catalog:",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vitest": "catalog:"
  },
  "homepage": "https://mastra.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mastra-ai/mastra.git",
    "directory": "packages/playground-ui"
  },
  "bugs": {
    "url": "https://github.com/mastra-ai/mastra/issues"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}

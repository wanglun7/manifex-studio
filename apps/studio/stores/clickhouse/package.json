{
  "name": "@mastra/clickhouse",
  "version": "1.10.1-alpha.0",
  "description": "Clickhouse provider for Mastra - includes db storage capabilities",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build:lib": "tsup --silent --config tsup.config.ts",
    "prepack": "tsx ../../scripts/generate-package-docs.ts",
    "build:watch": "tsup --watch --silent --config tsup.config.ts",
    "pretest": "docker compose up -d --wait",
    "test": "vitest run",
    "posttest": "docker compose down -v",
    "pretest:watch": "docker compose up -d",
    "test:watch": "vitest watch",
    "posttest:watch": "docker compose down -v",
    "lint": "eslint ."
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@clickhouse/client": "^1.20.0"
  },
  "devDependencies": {
    "@internal/lint": "workspace:*",
    "@internal/storage-test-utils": "workspace:*",
    "@internal/types-builder": "workspace:*",
    "@mastra/core": "workspace:*",
    "@types/node": "22.19.21",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "eslint": "^10.4.1",
    "tsup": "^8.5.1",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@mastra/core": ">=1.34.0-0 <2.0.0-0",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "homepage": "https://mastra.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mastra-ai/mastra.git",
    "directory": "stores/clickhouse"
  },
  "bugs": {
    "url": "https://github.com/mastra-ai/mastra/issues"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}

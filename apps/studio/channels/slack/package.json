{
  "name": "@mastra/slack",
  "version": "1.3.3-alpha.0",
  "description": "Slack integration for Mastra agents with app factory, OAuth, and slash commands",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@chat-adapter/slack": "^4.29.0"
  },
  "devDependencies": {
    "@mastra/core": "workspace:*",
    "@types/node": "^22.19.21",
    "tsup": "^8.5.1",
    "typescript": "^5.8.2",
    "vitest": "^4.1.8",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@mastra/core": "^1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mastra",
    "slack",
    "chatbot",
    "ai",
    "agent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mastra-ai/mastra.git",
    "directory": "channels/slack"
  },
  "homepage": "https://mastra.ai",
  "bugs": {
    "url": "https://github.com/mastra-ai/mastra/issues"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}

{
  "name": "mastra-turbo",
  "version": "0.1.11",
  "type": "module",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "22.19.21",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "changesets-changelog-github-local": "^1.0.1",
    "dotenv": "17.4.2",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "npm-run-all2": "^9.0.2",
    "path-to-regexp": "^8.3.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "semver": "^7.7.4",
    "tsc-files": "^1.1.4",
    "tsx": "catalog:",
    "turbo": "^2.9.12",
    "typescript": "catalog:",
    "vite": "^7.3.1",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "private": true,
  "scripts": {
    "changeset": "pnpm --filter @internal/changeset-cli start",
    "changeset-cli": "changeset",
    "ci:publish": "pnpm publish -r",
    "build": "pnpm turbo build --filter \"!./examples/*\" --filter \"!./examples/**/*\"",
    "build:server-adapters": "pnpm turbo build --filter \"./server-adapters/*\"",
    "build:integrations": "pnpm turbo build --filter \"./integrations/*\"",
    "build:packages": "pnpm turbo build --filter \"./packages/*\"",
    "build:combined-stores": "pnpm turbo build --filter \"./stores/*\"",
    "build:deployers": "pnpm turbo build --filter \"./deployers/*\"",
    "build:speech": "pnpm turbo build --filter \"./speech/*\"",
    "build:cli": "pnpm turbo build --filter ./packages/cli",
    "build:deployer": "pnpm turbo build --filter ./packages/deployer",
    "build:server": "pnpm turbo build --filter ./packages/server",
    "build:core": "pnpm turbo build --filter ./packages/core",
    "build:mcp": "pnpm turbo build --filter ./packages/mcp",
    "build:playground-ui": "pnpm turbo build --filter ./packages/playground-ui/",
    "build:rag": "pnpm turbo build --filter ./packages/rag",
    "build:memory": "pnpm turbo build --filter ./packages/memory",
    "build:docs-mcp": "pnpm turbo build --filter ./packages/mcp-docs-server",
    "build:evals": "pnpm turbo build --filter ./packages/evals",
    "build:mastracode": "pnpm turbo build --filter ./mastracode",
    "build:clients": "pnpm turbo build --filter \"./client-sdks/*\"",
    "build:schema-compat": "pnpm turbo build --filter ./packages/schema-compat",
    "build:auth": "pnpm turbo build --filter \"./auth/*\" --filter \"./packages/auth\" --filter \"./server-adapters/*\"",
    "build:observability": "pnpm turbo build --filter \"./observability/*\"",
    "build:workspaces": "pnpm turbo build --filter \"./workspaces/*\"",
    "dev:playground": "pnpm turbo run dev --filter ./packages/playground-ui --filter ./packages/playground --filter ./client-sdks/react",
    "generate:integration": "tsx ./integration-generator/index.ts",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:watch:combined-stores": "pnpm --filter \"./stores/*\" test:watch",
    "test:auth": "pnpm --filter \"./auth/*\" test && pnpm test:server-adapters",
    "test:cli": "pnpm --filter ./packages/cli test",
    "test:deployer": "pnpm --filter ./packages/deployer test",
    "test:server": "pnpm --filter ./packages/server test",
    "test:server-adapters": "pnpm --filter ./server-adapters/hono test && pnpm --filter ./server-adapters/express test && pnpm --filter ./server-adapters/nestjs test",
    "test:core": "pnpm --filter ./packages/core test",
    "test:mcp": "pnpm --filter ./packages/mcp test",
    "test:rag": "pnpm --filter ./packages/rag test",
    "test:clients": "pnpm --filter \"./client-sdks/*\" test",
    "test:combined-stores": "pnpm --filter \"./stores/*\" test",
    "test:memory": "pnpm --filter ./packages/memory test",
    "test:tool-builder": "pnpm test packages/core/src/tools/tool-builder/**",
    "test:schema-compat": "pnpm --filter ./packages/schema-compat test",
    "test:docs-mcp": "pnpm --filter ./packages/mcp-docs-server test",
    "test:editor": "pnpm --filter ./packages/editor test",
    "test:evals": "pnpm --filter ./packages/evals test",
    "test:durable": "pnpm test:durable:core && pnpm test:durable:inngest",
    "test:durable:core": "pnpm --filter @mastra/core test src/agent/durable/",
    "test:durable:inngest": "pnpm --filter @mastra/inngest test:suite",
    "test:durable:inngest:unit": "pnpm --filter @mastra/inngest test:unit",
    "test:mastracode": "pnpm --filter ./mastracode test",
    "test:agent-builder": "pnpm --filter ./packages/agent-builder test",
    "test:agent-builder:integration": "pnpm --filter @mastra/agent-builder-integration-tests test",
    "test:observability": "node scripts/test-observability.cjs",
    "test:e2e:client-js": "pnpm --filter \"client-js-e2e-tests-*\" test",
    "lint-staged": "lint-staged",
    "lint": "pnpm turbo --filter \"!./examples/**/*\" --filter \"!./docs/**/*\" --filter \"!@internal/playground\" lint",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "prettier:format": "prettier --write . --log-level warn",
    "prettier:format:check": "prettier --check .",
    "list-changed-files": "(git diff --name-only --diff-filter=ACMR $(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@' || echo 'main')...HEAD && git diff --name-only --diff-filter=ACMR && git diff --cached --name-only --diff-filter=ACMR) | sort -u",
    "list-prettier-files": "pnpm --silent list-changed-files | grep -E '\\.(js|mjs|ts|tsx|md|mdx|json|graphql|gql)$' | while IFS= read -r file; do [ ! -f \"$file\" ] || [ -L \"$file\" ] || printf '%s\\n' \"$file\"; done || true",
    "prettier:changed": "pnpm --silent list-prettier-files | xargs prettier --write --log-level warn",
    "typecheck": "pnpm --filter \"!./explorations/**/*\" -r typecheck",
    "format": "pnpm turbo --filter \"!./examples/**/*\" --filter \"!./docs/**/*\" --filter \"!@internal/playground\" lint -- --fix",
    "dev:services:up": "docker compose -f .dev/docker-compose.yaml up -d",
    "dev:services:down": "docker compose -f .dev/docker-compose.yaml down",
    "setup": "pnpm install && pnpm run build",
    "cleanup": "find . -type d \\( -name 'node_modules' -o -name 'dist' -o -name '.turbo' -o -name '.mastra' \\) -prune -exec rm -rf {} +"
  },
  "engines": {
    "pnpm": ">=11.0.0"
  },
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485",
  "dependencies": {
    "node-forge": "1.4.0",
    "resolve-from": "^5.0.0",
    "tinyglobby": "^0.2.17",
    "tokenx": "^1.3.0"
  }
}

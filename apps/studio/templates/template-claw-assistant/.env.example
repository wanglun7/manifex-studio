# Mastra Gateway — routes the chat model and provider-native web search.
# https://gateway.mastra.ai
MASTRA_GATEWAY_API_KEY=

# Turso (libSQL) database for observational + working memory.
# Use `file:./mastra.db` for local development.
TURSO_DATABASE_URL=file:./mastra.db
TURSO_AUTH_TOKEN=

# Optional: directory the agent is allowed to read/write/execute in.
# Defaults to ./workspace next to this template.
CLAW_WORKSPACE_DIR=

# Optional: run the browser headfully (default: headless).
BROWSER_HEADLESS=true

# Optional: connect to a hosted Chrome/Browserbase/Browserless instance instead of launching local Chromium.
# Recommended for server deployments where the runtime image does not include browser system libraries.
BROWSER_CDP_URL=

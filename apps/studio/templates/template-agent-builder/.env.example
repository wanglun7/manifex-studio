# Required
# Agent Builder is an Enterprise feature. Use a valid license key (at least 32 characters).
MASTRA_EE_LICENSE=
OPENAI_API_KEY=

# Required: WorkOS AuthKit + RBAC
# WORKOS_COOKIE_PASSWORD must be at least 32 characters.
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=
WORKOS_REDIRECT_URI=http://localhost:4111/api/auth/callback

# Optional: Composio tool provider
# Enables the Composio provider only when set.
COMPOSIO_API_KEY=

# Optional: Slack channel provider
# Enables Slack only when SLACK_APP_CONFIG_TOKEN and SLACK_APP_CONFIG_REFRESH_TOKEN are set.
SLACK_APP_CONFIG_TOKEN=
SLACK_APP_CONFIG_REFRESH_TOKEN=
SLACK_BASE_URL=

# Optional: Browserbase + Stagehand browser support
# Enables Agent Builder browser tools only when both values are set.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

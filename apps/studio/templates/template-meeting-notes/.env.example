# Mastra Gateway — single key proxies to OpenAI, Anthropic, Google, etc.
# https://mastra.ai/docs/models/gateways/mastra
MASTRA_GATEWAY_API_KEY=

# Turso (libSQL) — used for observability + saved meeting notes
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Zoom Server-to-Server OAuth app
# Create one at https://marketplace.zoom.us/ → "Server-to-Server OAuth"
# Required scopes:
#   cloud_recording:read:list_user_recordings:admin
#   cloud_recording:read:recording:admin
#   user:read:user:admin
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# Optional: push action items as Linear issues
LINEAR_API_KEY=

# Optional: push notes to a Notion page (via Notion MCP server)
NOTION_API_KEY=

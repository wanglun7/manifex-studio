{
  "name": "@templates/agent",
  "version": "1.0.0",
  "description": "A Mastra agent that consumes tools from an MCP server for documentation assistance",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev:mastra": "mastra dev",
    "dev:mcp": "tsx src/mcp-server/server.ts",
    "dev": "concurrently \"pnpm run dev:mastra\" \"pnpm run dev:mcp\"",
    "build": "mastra build",
    "start": "mastra start"
  },
  "keywords": [
    "agent",
    "mastra",
    "documentation",
    "mcp"
  ],
  "author": "",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "@mastra/core": "latest",
    "@mastra/libsql": "latest",
    "@mastra/loggers": "latest",
    "@mastra/mcp": "latest",
    "@mastra/memory": "latest",
    "@mastra/observability": "latest"
  },
  "devDependencies": {
    "@types/node": "^24.10.9",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "mastra": "latest",
    "tsx": "catalog:",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  }
}

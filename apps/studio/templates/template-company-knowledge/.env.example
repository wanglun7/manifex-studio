# Mastra Gateway — routes models and provider-native web search.
# Get one at https://gateway.mastra.ai
MASTRA_GATEWAY_API_KEY=

# Neon Postgres connection string (with `?sslmode=require`).
# pgvector must be available on the database; Neon supports it out of the box.
DATABASE_URL=postgresql://user:pass@host.neon.tech/dbname?sslmode=require

# Linear API key (Personal API key or OAuth token).
# Used by the Linear MCP server at mcp.linear.app for live issue/project lookups.
# https://linear.app/settings/account/security
LINEAR_API_KEY=

# Notion internal integration token.
# Used by the Notion MCP server (@notionhq/notion-mcp-server) for live page/database lookups.
# https://www.notion.so/profile/integrations
NOTION_API_KEY=

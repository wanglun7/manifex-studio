{
  "name": "mastra-docs",
  "version": "0.0.49",
  "private": true,
  "repository": "https://github.com/mastra-ai/mastra",
  "homepage": "https://mastra.ai",
  "bugs": "https://github.com/mastra-ai/mastra",
  "scripts": {
    "docusaurus": "docusaurus",
    "dev": "docusaurus start",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "validate:frontmatter": "tsx scripts/validate-frontmatter.ts",
    "validate:reference-sidebar": "tsx scripts/validate-reference-sidebar-sort.ts",
    "validate:reference-sidebar:fix": "tsx scripts/validate-reference-sidebar-sort.ts --fix",
    "validate:sidebar-docs": "tsx scripts/validate-sidebar-docs.ts",
    "validate": "npm-run-all --parallel validate:frontmatter validate:reference-sidebar validate:sidebar-docs",
    "format": "prettier --write .",
    "vale:download": "node scripts/vale/download.mjs",
    "vale": "scripts/vale/bin/vale",
    "vale:sync": "scripts/vale/bin/vale sync",
    "lint:vale": "scripts/vale/bin/vale src/content/en/docs src/content/en/guides src/content/en/reference src/learn/content",
    "lint:vale:ai": "pnpm lint:vale --minAlertLevel=error --output=line",
    "lint:remark": "remark --no-stdout --frail --quiet --ext mdx src/content/en/docs src/content/en/guides src/content/en/reference src/learn/content",
    "lint:prose": "npm-run-all --parallel lint:vale lint:remark",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:e2e": "pnpm exec playwright test",
    "test:smoke": "pnpm exec playwright test tests/smoke.spec.ts --project=desktop",
    "test:og": "pnpm exec playwright test tests/og-image.spec.ts --project=desktop",
    "test:navigation": "pnpm exec playwright test tests/navigation.spec.ts"
  },
  "dependencies": {
    "@copilotkit/react-ui": "1.8.10",
    "@docusaurus/core": "^3.9.2",
    "@docusaurus/faster": "^3.9.2",
    "@docusaurus/plugin-content-docs": "^3.9.2",
    "@docusaurus/plugin-vercel-analytics": "^3.9.2",
    "@docusaurus/preset-classic": "^3.9.2",
    "@docusaurus/remark-plugin-npm2yarn": "^3.9.2",
    "@docusaurus/theme-common": "^3.9.2",
    "@headlessui/react": "^2.2.9",
    "@hookform/resolvers": "^5.2.2",
    "@kapaai/react-sdk": "^0.9.2",
    "@mdx-js/react": "^3.1.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-virtual": "^3.13.22",
    "@vercel/analytics": "^2.0.1",
    "algoliasearch": "^5.49.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.5",
    "dotenv": "^17.3.1",
    "fs-extra": "^11.3.4",
    "hast-util-select": "^6.0.4",
    "hast-util-to-mdast": "^10.1.2",
    "lucide-react": "^0.552.0",
    "node-forge": "^1.3.3",
    "posthog-docusaurus": "^2.0.5",
    "posthog-js": "^1.360.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.2",
    "react-hotkeys-hook": "^5.2.4",
    "rehype-parse": "^9.0.1",
    "rehype-remark": "^10.0.1",
    "remark-stringify": "^11.0.0",
    "tinyglobby": "^0.2.15",
    "unified": "^11.0.5",
    "use-stick-to-bottom": "^1.1.3",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.9.2",
    "@docusaurus/tsconfig": "^3.9.2",
    "@docusaurus/types": "^3.9.2",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/fs-extra": "^11.0.4",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "22.19.13",
    "baseline-browser-mapping": "^2.10.8",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.8",
    "remark": "^15.0.1",
    "remark-cli": "^12.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-lint": "^10.0.1",
    "remark-lint-heading-increment": "^4.0.1",
    "remark-lint-no-emphasis-as-heading": "^4.0.1",
    "remark-lint-no-undefined-references": "^5.0.2",
    "remark-lint-ordered-list-marker-value": "^4.0.1",
    "remark-lint-unordered-list-marker-style": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-preset-lint-consistent": "^6.0.1",
    "remark-preset-lint-recommended": "^7.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "unist-util-visit": "^5.1.0",
    "vitest": "^4.1.0"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  }
}
